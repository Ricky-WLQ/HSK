# Copy to .env and fill in. In PRODUCTION set these in Zeabur's encrypted env vars.
# Never commit real secrets. This file (with placeholders) IS committed as a checklist.

# ── Database: Zeabur managed Postgres ── (REQUIRED)
# In Zeabur, set: DATABASE_URL=${POSTGRES_CONNECTION_STRING}
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public"

# ── Better Auth ── (REQUIRED)
# BETTER_AUTH_SECRET: generate a strong 32+ char secret: openssl rand -base64 32
# BETTER_AUTH_URL: MUST be the public site URL in production (e.g. https://hsk-online.zeabur.app);
#                  the app refuses to boot in production if this is unset or points at localhost.
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://localhost:3000"

# ── Teacher portal access ── (REQUIRED to let anyone become a teacher)
# Secret code a signed-in user enters at /become-teacher to gain the "teacher" role.
# Generate a long random value (e.g. openssl rand -base64 24) and share only with real
# teachers. If unset/short (<8 chars), teacher self-signup is disabled (the route returns 503).
TEACHER_SIGNUP_CODE=""

# ── DeepSeek (AI) — build-time vocab/exam content generation ──
# Used by scripts only; not required at runtime.
# DEEPSEEK_API_KEY=""
# DEEPSEEK_MODEL="deepseek-v4-flash"

# ── TTS: Edge TTS (Microsoft neural voices) ── (no key needed)
# Mandarin audio uses the free Edge TTS endpoint (edge-tts-universal in the runtime,
# python edge-tts in scripts/pregenerate-tts.py). No API key or env var required.

# ── SiliconFlow (build-time only: ASR audio audit, vocab definitions, future images) ──
# Optional at runtime. Used by scripts (pinyin/ASR audit, DeepSeek pipelines, images).
# SILICONFLOW_API_KEY=""
# IMAGE_GENERATION_MODEL="baidu/ERNIE-Image-Turbo"

# ── Cloudflare R2 (TTS audio bank) ── (REQUIRED for audio persistence)
# S3 credentials from an R2 API token (Access Key ID = token ID, Secret = SHA-256 of token value).
R2_ACCOUNT_ID=""
R2_ENDPOINT="https://<ACCOUNT_ID>.r2.cloudflarestorage.com"
R2_BUCKET=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_PUBLIC_URL=""

# ── Ably (live-quiz realtime) — Phase 3 ──
# ABLY_API_KEY=""

# ── LiveKit (video classes) — Phase 4 ──
# LIVEKIT_API_KEY=""
# LIVEKIT_API_SECRET=""
# LIVEKIT_URL=""

# ── Stripe (payments) — Phase 4 ──
# STRIPE_SECRET_KEY=""
# STRIPE_WEBHOOK_SECRET=""
