// HSK app — Prisma schema (Prisma 6).
// Phase 0 scope: authentication models only (Better Auth + admin plugin fields).
// Later phases add app models (vocab, exams, classes, scheduling, etc.) via
// incremental migrations.
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// Better Auth core models (+ admin plugin fields)
// `role` carries our RBAC: "student" (default) | "teacher" | "admin".
// ============================================================

model User {
  id            String  @id
  name          String
  email         String  @unique
  emailVerified Boolean @default(false)
  image         String?

  // admin plugin fields
  role       String    @default("student")
  banned     Boolean   @default(false)
  banReason  String?
  banExpires DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions      Session[]
  accounts      Account[]
  vocabProgress VocabProgress[]
  hskAttempts   HskAttempt[]
  hskMistakes   HskMistake[]

  // Phase 3 — teacher portal
  teacherClasses        Class[]                @relation("TeacherClasses")
  classMemberships      ClassMember[]          @relation("StudentMemberships")
  authoredComments      ClassComment[]         @relation("AuthoredComments")
  assignmentCompletions AssignmentCompletion[] @relation("StudentCompletions")
  teacherLiveSessions   LiveSession[]          @relation("TeacherLiveSessions")
  liveParticipations    LiveParticipant[]      @relation("StudentParticipations")

  // Phase 4 — scheduling / live video classes
  teacherSessions ClassSession[]   @relation("TeacherSessions")
  sessionBookings SessionBooking[] @relation("StudentBookings")

  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // admin plugin field
  impersonatedBy String?

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

// ===== App models =====

// Per-user vocabulary mastery (spaced-repetition style; 0-5 scale).
model VocabProgress {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  level        String // HSK level: "1".."6","7-9"
  wordId       String // vocab word id, e.g. "hsk1-0001"
  hanzi        String
  mastery      Int       @default(0) // 0-5 (4+ = mastered)
  reviewCount  Int       @default(0)
  correctCount Int       @default(0)
  lastReviewed DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([userId, wordId])
  @@index([userId, level])
}

// ===== Phase 2: practice / exam engine =====

// One attempt at a practice set / mock / diagnostic (per user, per content).
model HskAttempt {
  id             String    @id @default(cuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  level          String // "1".."6","7-9"
  section        String // "listening" | "reading" | "writing" | "translation" | "speaking"
  contentId      String // practice set / exam id, e.g. "hsk3-reading-001"
  kind           String    @default("practice") // "practice" | "mock" | "diagnostic"
  status         String    @default("in_progress") // "in_progress" | "completed"
  totalQuestions Int       @default(0)
  correctCount   Int?
  answers        String? // JSON { [questionId]: answer }
  startedAt      DateTime  @default(now())
  completedAt    DateTime?

  @@index([userId, level, section])
  @@index([userId, status])
}

// Wrong-answer mistake notebook + AI analysis.
model HskMistake {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  level           String
  section         String
  contentId       String
  questionId      String
  questionText    String
  questionContext String?
  options         String? // JSON array
  userAnswer      String
  correctAnswer   String
  analysis        String? // JSON { summary, analysis, relatedVocab }
  status          String   @default("new") // "new" | "reviewed" | "mastered"
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([userId, level, section, contentId, questionId])
  @@index([userId, level, section, status])
}

// ============================================================
// Phase 3 — Teacher portal (classes, assignments, messaging, live-quiz).
// Architecture mirrors the proven CET app: the DB is the source of truth;
// the live-quiz pushes changes over SSE (verified to stream un-buffered on
// Zeabur) instead of CET's Supabase Realtime.
// ============================================================

model Class {
  id           String         @id @default(cuid())
  name         String
  description  String?
  teacherId    String
  teacher      User           @relation("TeacherClasses", fields: [teacherId], references: [id], onDelete: Cascade)
  inviteCode   String         @unique // 8-char alphanumeric, regenerable
  level        String? // optional default HSK focus: "1".."6","7-9" or null
  isActive     Boolean        @default(true)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  members      ClassMember[]
  assignments  Assignment[]
  comments     ClassComment[]
  liveSessions LiveSession[]
  sessions     ClassSession[]

  @@index([teacherId])
  @@index([inviteCode])
}

// Student ↔ class membership (enrollment).
model ClassMember {
  id        String   @id @default(cuid())
  classId   String
  class     Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  studentId String
  student   User     @relation("StudentMemberships", fields: [studentId], references: [id], onDelete: Cascade)
  joinedAt  DateTime @default(now())

  @@unique([classId, studentId])
  @@index([classId])
  @@index([studentId])
}

// Teacher↔student or class-wide message thread (studentId null = class-wide).
model ClassComment {
  id        String   @id @default(cuid())
  classId   String
  class     Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation("AuthoredComments", fields: [authorId], references: [id], onDelete: Cascade)
  studentId String? // null = class-wide announcement; set = thread with this student
  body      String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([classId, studentId, createdAt])
  @@index([studentId, isRead])
}

// A teacher-assigned task targeting existing HSK content.
model Assignment {
  id          String                 @id @default(cuid())
  classId     String
  class       Class                  @relation(fields: [classId], references: [id], onDelete: Cascade)
  teacherId   String
  title       String
  description String?
  type        String // "practice" | "grammar" | "mock" | "diagnostic" | "vocab"
  target      String                 @default("{}") // JSON: e.g. {"level":"3","section":"reading"} or {"setId":"..."}
  dueDate     DateTime?
  isActive    Boolean                @default(true)
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  completions AssignmentCompletion[]

  @@index([classId, isActive])
  @@index([classId, dueDate])
  @@index([teacherId])
}

// Per-student completion of an assignment; links to the student's HskAttempt.
model AssignmentCompletion {
  id              String     @id @default(cuid())
  assignmentId    String
  assignment      Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  studentId       String
  student         User       @relation("StudentCompletions", fields: [studentId], references: [id], onDelete: Cascade)
  status          String     @default("not_started") // "not_started" | "in_progress" | "completed"
  attemptId       String? // HskAttempt.id
  score           Float?
  correctCount    Int?
  totalQuestions  Int?
  feedback        String? // optional teacher note
  completedAt     DateTime?
  markedByTeacher Boolean    @default(false)

  @@unique([assignmentId, studentId])
  @@index([studentId])
  @@index([assignmentId, status])
}

// ── Live class quiz (Kahoot-style, synchronized by the teacher) ──

model LiveSession {
  id           String            @id @default(cuid())
  classId      String
  class        Class             @relation(fields: [classId], references: [id], onDelete: Cascade)
  teacherId    String
  teacher      User              @relation("TeacherLiveSessions", fields: [teacherId], references: [id], onDelete: Cascade)
  joinCode     String            @unique // short code students enter to join
  title        String?
  questions    String            @default("[]") // JSON: [{ q, pinyin?, options:[...], correct }]
  status       String            @default("waiting") // "waiting" | "running" | "ended"
  currentQIdx  Int               @default(0) // teacher advances
  revealed     Boolean           @default(false) // reveal answer for currentQIdx
  startedAt    DateTime          @default(now())
  endedAt      DateTime?
  participants LiveParticipant[]
  answers      LiveAnswer[]

  @@index([classId])
  @@index([joinCode])
}

model LiveParticipant {
  id        String      @id @default(cuid())
  sessionId String
  session   LiveSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  studentId String
  student   User        @relation("StudentParticipations", fields: [studentId], references: [id], onDelete: Cascade)
  name      String // display name in the quiz
  joinedAt  DateTime    @default(now())
  joinQIdx  Int         @default(0) // late-join: earlier questions count blank

  @@unique([sessionId, studentId])
  @@index([sessionId])
}

// Per-question answer events — the source of truth for live aggregation.
model LiveAnswer {
  id          String      @id @default(cuid())
  sessionId   String
  session     LiveSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  studentId   String
  questionIdx Int
  answer      String
  correct     Boolean?
  submittedAt DateTime    @default(now())

  @@unique([sessionId, studentId, questionIdx])
  @@index([sessionId, questionIdx])
}

// ============================================================
// Phase 4 — scheduling & live video classes (payments dropped per owner).
// The teacher schedules a ClassSession (1:1 when maxParticipants=1, else group,
// duration capped at 120 min); enrolled students book a seat (capacity-enforced).
// `videoRoom` is populated later when a WebRTC provider is wired in.
// ============================================================

model ClassSession {
  id                 String           @id @default(cuid())
  classId            String
  class              Class            @relation(fields: [classId], references: [id], onDelete: Cascade)
  teacherId          String
  teacher            User             @relation("TeacherSessions", fields: [teacherId], references: [id], onDelete: Cascade)
  title              String?
  startAt            DateTime         @db.Timestamptz(3)
  durationMin        Int              @default(60) // enforced <= 120 in app
  endAt              DateTime         @db.Timestamptz(3)
  maxParticipants    Int              @default(1) // 1 = one-on-one; >1 = group
  status             String           @default("scheduled") // scheduled | live | ended | canceled
  videoRoom          String? // provider room name, set when video is enabled
  recordingRequested Boolean          @default(false)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  bookings           SessionBooking[]

  @@index([classId, startAt])
  @@index([teacherId, startAt])
}

model SessionBooking {
  id        String       @id @default(cuid())
  sessionId String
  session   ClassSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  studentId String
  student   User         @relation("StudentBookings", fields: [studentId], references: [id], onDelete: Cascade)
  status    String       @default("booked") // booked | canceled
  bookedAt  DateTime     @default(now())

  @@unique([sessionId, studentId])
  @@index([studentId])
  @@index([sessionId, status])
}
